{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": [
        "post",
        "get",
        "put",
        "delete"
      ]
    },
    {
      "type": "http",
      "direction": "out",
      "name": "res"
    },
    {
      "type": "queue",
      "direction": "out",
      "name": "downlinkQueue",
      "queueName": "lorawan-downlink",
      "connection": "AzureWebJobsStorage"
    }
  ],
  "scriptFile": "index.js"
}
