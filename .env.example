# ============================================
# Red Dog Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Discord ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_ALLOWED_USERS=your_discord_user_id_here

# --- AI / OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model for AI responses (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Database (Azure SQL / MSSQL) ---
DATABASE_ENABLED=true
DATABASE_TYPE=mssql
# Connection string for the SERVER (no Database= needed, databases are listed separately below)
#   Server=your-server.database.windows.net;User Id=your-username;Password=your-password;Encrypt=true;TrustServerCertificate=false;
DATABASE_CONNECTION_STRING=Server=your-server.database.windows.net;User Id=your-username;Password=your-password;Encrypt=true;TrustServerCertificate=false;
# Comma-separated list of database names Red Dog should connect to
DATABASE_NAMES=MyFirstDB,MySecondDB

# --- Red Dog API Server ---
# API_PORT=3001

# --- Billing System (Stripe) ---
# Get these from https://dashboard.stripe.com/apikeys
# For production use live keys (sk_live_ and pk_live_)
# For testing use test keys (sk_test_ and pk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# --- Azure Blob Storage (Provider Data) ---
# For storing data retrieved from external providers via Trevor
# Connection string format: DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_storage_account;AccountKey=your_key;EndpointSuffix=core.windows.net

# --- Azure Service Bus (Trevor Communication) ---
# For communicating with Trevor Tractor to request/receive provider data
# Connection string from Azure Portal -> Service Bus Namespace -> Shared access policies
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your_key
# Service Bus subscription name (default: reddog-bot)
SERVICE_BUS_SUBSCRIPTION=reddog-bot

# --- Persistent Chat Storage ---
# Farm identifier for organizing chat history (default: grassgum)
FARM_ID=grassgum
# Enable persistent chat storage in blob storage (default: true)
PERSISTENT_CHAT_ENABLED=true
# Auto-save chat history every N messages (default: 5)
CHAT_AUTOSAVE_INTERVAL=5
# Maximum conversation history to keep in memory (default: 20)
CONVERSATION_HISTORY_LENGTH=20

# --- Social Media Integration ---
# Instagram (via Facebook Graph API)
# Get credentials from https://developers.facebook.com/apps/
INSTAGRAM_CLIENT_ID=your_instagram_app_id_here
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret_here

# Facebook & Facebook Ads Manager
# Same app as Instagram, get from https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here
FACEBOOK_AD_ACCOUNT_ID=your_ad_account_id_here

# LinkedIn
# Get credentials from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# WhatsApp Business API (via Meta Cloud API)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1. Create a Meta Business Account at business.facebook.com
# 2. Add WhatsApp product to your app at developers.facebook.com
# 3. Get Phone Number ID and generate a permanent System User Token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
# System User Token (permanent token from Meta Business Manager -> System Users)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_system_user_token_here

# OAuth redirect URI (must match what's configured in each platform's app settings)
OAUTH_REDIRECT_URI=https://your-app-url.azurecontainerapps.io/auth/callback

# --- Azure Functions (Device Control) ---
# URL of your deployed Azure Function App (no trailing slash)
# e.g. https://my-func-app.azurewebsites.net/api
AZURE_FUNCTIONS_URL=https://your-function-app.azurewebsites.net/api
# Function-level API key from Azure Portal -> Function App -> Functions -> App keys
AZURE_FUNCTIONS_KEY=your_function_app_key_here

# --- WattWatchers ---
# Site ID for WattWatchers privacy isolation (default: default)
WATTWATCHERS_SITE_ID=default
# API key from WattWatchers portal
WATTWATCHERS_API_KEY=your_wattwatchers_api_key_here
# Comma-separated device IDs for WattWatchers
WATTWATCHERS_DEVICE_IDS=D123456,D789012

# --- LoRaWAN Network Server ---
LORAWAN_NETWORK_SERVER=https://your-lorawan-server.com
LORAWAN_API_KEY=your_lorawan_api_key_here
LORAWAN_APPLICATION_ID=your_lorawan_app_id_here

# --- Twilio (SMS Confirmations) ---
# Used to send SMS device control confirmation requests and receive YES/NO replies
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# Your personal phone number to receive SMS confirmations
ALERT_PHONE_NUMBER=+61400000000
# Set the Twilio SMS webhook to: https://your-app-url/api/twilio/sms

# --- Gateway (used by entrypoint.sh for Azure deployment) ---
# MOLTBOT_GATEWAY_TOKEN=your_gateway_token_here
# MOLTBOT_MODEL=openrouter/anthropic/claude-3.5-sonnet
# MOLTBOT_PERSONA_NAME=Red Dog
# GATEWAY_PORT=18789
