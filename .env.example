# ============================================
# Red Dog Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Discord ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_ALLOWED_USERS=your_discord_user_id_here

# --- AI / OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model for AI responses (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Database (Azure SQL / MSSQL) ---
DATABASE_ENABLED=true
DATABASE_TYPE=mssql
# Connection string for the SERVER (no Database= needed, databases are listed separately below)
#   Server=your-server.database.windows.net;User Id=your-username;Password=your-password;Encrypt=true;TrustServerCertificate=false;
DATABASE_CONNECTION_STRING=Server=your-server.database.windows.net;User Id=your-username;Password=your-password;Encrypt=true;TrustServerCertificate=false;
# Comma-separated list of database names Red Dog should connect to
DATABASE_NAMES=MyFirstDB,MySecondDB

# --- Red Dog API Server ---
# API_PORT=3001

# --- Billing System (Stripe) ---
# Get these from https://dashboard.stripe.com/apikeys
# For production use live keys (sk_live_ and pk_live_)
# For testing use test keys (sk_test_ and pk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# --- Azure Blob Storage (Provider Data) ---
# For storing data retrieved from external providers via Trevor
# Connection string format: DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_storage_account;AccountKey=your_key;EndpointSuffix=core.windows.net

# --- Azure Service Bus (Trevor Communication) ---
# For communicating with Trevor Tractor to request/receive provider data
# Connection string from Azure Portal -> Service Bus Namespace -> Shared access policies
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your_key
# Service Bus subscription name (default: reddog-bot)
SERVICE_BUS_SUBSCRIPTION=reddog-bot

# --- Persistent Chat Storage ---
# Farm identifier for organizing chat history (default: grassgum)
FARM_ID=grassgum
# Enable persistent chat storage in blob storage (default: true)
PERSISTENT_CHAT_ENABLED=true
# Auto-save chat history every N messages (default: 5)
CHAT_AUTOSAVE_INTERVAL=5
# Maximum conversation history to keep in memory (default: 20)
CONVERSATION_HISTORY_LENGTH=20

# --- Meta (Facebook) Developer App ---
# Create your app at https://developers.facebook.com/apps/
# App Dashboard → App Settings → Basic
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# Webhook verify token — enter this same value in Meta Developer Console → Webhooks → Verify Token
META_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token_here

# Page Access Token — Graph API Explorer → select your Page → Generate Token
# Used for: Messenger replies, Instagram replies, page posts
META_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Dashboard redirect after OAuth success/failure
DASHBOARD_URL=https://your-dashboard-url.com

# --- Social Media Integration ---

# Instagram
# App ID + Secret from developers.facebook.com → Your App → App Settings → Basic
INSTAGRAM_CLIENT_ID=your_meta_app_id_here
INSTAGRAM_CLIENT_SECRET=your_meta_app_secret_here
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
# Instagram Business Account ID (Graph API: GET /{page-id}?fields=instagram_business_account)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
# Page Access Token for Instagram DMs and comment replies
INSTAGRAM_PAGE_ACCESS_TOKEN=your_page_access_token_here
INSTAGRAM_CALLBACK=https://clawdbot.happybush-1b235e08.australiasoutheast.azurecontainerapps.io/api/social/auth/callback

# Facebook & Facebook Ads Manager
FACEBOOK_CLIENT_ID=your_meta_app_id_here
FACEBOOK_CLIENT_SECRET=your_meta_app_secret_here
FACEBOOK_AD_ACCOUNT_ID=your_ad_account_id_here
# Tokens from Meta Business Manager → System Users or Graph API Explorer
FACEBOOK_MARKETING_API=your_facebook_marketing_api_token_here
FACEBOOK_CATALOG_API=your_facebook_catalog_api_token_here
FACEBOOK_ADS_TOKEN=your_facebook_ads_token_here

# Facebook Threads
FACEBOOK_THREADS_APP_ID=your_threads_app_id_here
FACEBOOK_THREADS_CLIENT_SECRET=your_threads_client_secret_here

# LinkedIn
# Get credentials from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# WhatsApp Business API (via Meta Cloud API)
# developers.facebook.com → Your App → WhatsApp → API Setup
# Phone Number ID and Business Account ID shown in API Setup panel
# Access Token: use System User Token from Meta Business Manager → System Users (permanent)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_system_user_token_here

# OAuth redirect URI — must match exactly in each platform's app settings
OAUTH_REDIRECT_URI=https://clawdbot.happybush-1b235e08.australiasoutheast.azurecontainerapps.io/api/social/auth/callback

# --- Sensor API (Azure APIM + per-farm Key Vault) ---
# APIM base URL for sensor data (no trailing slash)
# e.g. https://apim-zerosumag.azure-api.net/sensor-api
SENSOR_APIM_URL=https://your-apim.azure-api.net/sensor-api
# Red Dog's own APIM subscription key (from APIM portal -> Subscriptions)
SENSOR_APIM_KEY=your_apim_subscription_key_here
# Secret name inside each farm's Key Vault that holds the sensor API key
# Default: "sensor-api-key"
SENSOR_KEYVAULT_SECRET=sensor-api-key

# --- Azure Identity (Key Vault access) ---
# For local dev / service principal auth (not needed in production with Managed Identity)
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here
# In production (Azure Container Apps), use Managed Identity — no credentials needed

# --- Farm Configuration ---
# Default farm name — must match the "Name" column in zerosumag [Site Overview] table
# Key Vault is derived automatically: "Grassgum Farm" → "GrassgumFarm"
FARM_ID=Grassgum Farm

# --- Azure Functions (Device Control) ---
# URL of your deployed Azure Function App (no trailing slash)
# e.g. https://my-func-app.azurewebsites.net/api
AZURE_FUNCTIONS_URL=https://your-function-app.azurewebsites.net/api
# Function-level API key from Azure Portal -> Function App -> Functions -> App keys
AZURE_FUNCTIONS_KEY=your_function_app_key_here

# --- WattWatchers ---
# Site ID for WattWatchers privacy isolation (default: default)
WATTWATCHERS_SITE_ID=default
# API key from WattWatchers portal
WATTWATCHERS_API_KEY=your_wattwatchers_api_key_here
# Comma-separated device IDs for WattWatchers
WATTWATCHERS_DEVICE_IDS=D123456,D789012

# --- LoRaWAN Network Server ---
LORAWAN_NETWORK_SERVER=https://your-lorawan-server.com
LORAWAN_API_KEY=your_lorawan_api_key_here
LORAWAN_APPLICATION_ID=your_lorawan_app_id_here

# --- Twilio (SMS Confirmations) ---
# Used to send SMS device control confirmation requests and receive YES/NO replies
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# Your personal phone number to receive SMS confirmations
ALERT_PHONE_NUMBER=+61400000000
# Set the Twilio SMS webhook to: https://your-app-url/api/twilio/sms

# --- Smart Checks (Multi-Parameter Automation Triggers) ---
# LoRaWAN device ID for the irrigation pump relay (relay_id 1)
PUMP_DEVICE_ID=irrigation-pump-01
# LoRaWAN device ID for the water valve digital output (pin_id 1)
VALVE_DEVICE_ID=water-valve-01
# WattWatchers device ID for non-essential load shedding
LOAD_SWITCH_DEVICE_ID=non-essential-circuits
# WattWatchers switch ID to open for load shedding (e.g. S3)
LOAD_SWITCH_ID=S3
# Conditions evaluated by GET /api/smart-checks:
#   battery_and_soil: Battery 75-100% AND soil moisture < 60% → suggest irrigation
#   load_and_battery: Battery < 30% AND load > 2000W → suggest load shedding
#   solar_and_battery: Solar > 2000W AND battery < 70% → defer loads, charge first

# --- Gateway (used by entrypoint.sh for Azure deployment) ---
# MOLTBOT_GATEWAY_TOKEN=your_gateway_token_here
# MOLTBOT_MODEL=openrouter/anthropic/claude-3.5-sonnet
# MOLTBOT_PERSONA_NAME=Red Dog
# GATEWAY_PORT=18789

